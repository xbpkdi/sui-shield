# ============================================================
# SuiShield — Sui Overflow 2026
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file containing secrets.
#
# Judge quick path: set Google OAuth + deploy Move contract + sponsor key
# → Demo Lab → Normal Success → live gasless mint on devnet.
# See SUBMISSION.md for the 3-minute demo script.
# ============================================================

# --- Sui Network ---
# Use devnet for zkLogin with your own Google OAuth client (no Mysten whitelist).
# Use testnet only with a whitelisted client ID or self-hosted zkLogin prover.
NEXT_PUBLIC_SUI_NETWORK=devnet

# --- RPC Endpoints (server-side only) ---
# Primary RPC URL. Keep this server-side; do not expose to browser.
SUI_RPC_PRIMARY=https://fullnode.devnet.sui.io:443

# Backup RPC endpoints (optional)
SUI_RPC_BACKUP_1=
SUI_RPC_BACKUP_2=

# --- Sponsor Service (SERVER-SIDE ONLY) ---
# CRITICAL: Never use a NEXT_PUBLIC_ prefix for this variable.
# Never expose to the client, never log, never commit.
# Supported formats:
#   Bech32:   suiprivkey1<...>   (output of `sui keytool export`)
#   Base64:   <base64-encoded 32-byte raw secret key>
# For production, use a proper secrets manager (AWS Secrets Manager, GCP Secret Manager, etc.)
SUI_SPONSOR_PRIVATE_KEY=

# --- Deployed Move Contract (devnet) ---
# Set these after deploying move/starter_badge/ with `sui client publish`
# Package ID from the deployment output
NEXT_PUBLIC_BADGE_PACKAGE_ID=

# Shared BadgeRegistry object ID (created during package init)
NEXT_PUBLIC_STARTER_BADGE_REGISTRY_ID=

# --- Sui Explorer ---
# Base URL for transaction and address links (no trailing slash)
NEXT_PUBLIC_SUI_EXPLORER_BASE_URL=https://suiexplorer.com

# --- API Keys for premium RPC providers (server-side only) ---
QUICKNODE_ENDPOINT=
CHAINSTACK_ENDPOINT=

# --- zkLogin — passwordless gasless mint (free, no Enoki subscription) ---
# Google OAuth Web client ID from https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins: http://localhost:3000
# Authorized redirect URIs:       http://localhost:3000/callback
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Server-only salt master secret (32+ random chars). Derives per-user zkLogin salt locally
# so you don't need Mysten/Enoki client-ID whitelisting. NEVER commit or expose to browser.
# Generate: openssl rand -base64 32
SUI_ZKLOGIN_SALT_SECRET=

# Optional: override zkLogin prover URL (defaults: testnet/mainnet → prover.mystenlabs.com, devnet → prover-dev)
# SUI_ZKLOGIN_PROVER_URL=https://prover.mystenlabs.com/v1

# Optional: Enoki API key — only for dApp Kit ConnectModal wallet registration.
# NEXT_PUBLIC_ENOKI_API_KEY=

# --- Sponsor API hardening (optional, production) ---
# Extra allowed origin host for /api/sponsor/* (e.g. https://your-domain.com)
# SPONSOR_ALLOWED_ORIGIN=

# --- Feature flags ---
# Set to false once the Move contract is deployed and SUI_SPONSOR_PRIVATE_KEY is set
NEXT_PUBLIC_DEMO_MODE=true

# --- Wallet compatibility ---
# Controls whether Phantom users can proceed past the sponsored-transaction compatibility
# warning in Demo Lab. Default: false (recommended for hackathon demo).
#
# false: Phantom real mint blocked → user directed to Slush. Simulation still works.
# true:  Phantom shows a warning modal → user may explicitly continue (developer mode).
#
# Slush Wallet is always allowed regardless of this flag.
NEXT_PUBLIC_ALLOW_PHANTOM_SPONSORED_TX=false
