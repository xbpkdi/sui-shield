# ============================================================
# SuiShield Environment Configuration
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file containing secrets.
# ============================================================

# --- Sui Network ---
NEXT_PUBLIC_SUI_NETWORK=testnet

# --- RPC Endpoints (server-side only) ---
# Primary RPC URL. Keep this server-side; do not expose to browser.
SUI_RPC_PRIMARY=https://fullnode.testnet.sui.io:443

# Backup RPC endpoints (comma-separated)
SUI_RPC_BACKUP_1=
SUI_RPC_BACKUP_2=

# --- Sponsor Service (server-side ONLY) ---
# TODO: Replace with a proper secrets manager (AWS Secrets Manager, Vault, etc.)
# NEVER set a real private key here for production use.
# SPONSOR_PRIVATE_KEY=<placeholder — handled server-side only>

# Move package that contains the Starter Badge contract
NEXT_PUBLIC_BADGE_PACKAGE_ID=

# --- API Keys for premium RPC providers (server-side only) ---
QUICKNODE_ENDPOINT=
CHAINSTACK_ENDPOINT=

# --- Feature flags ---
NEXT_PUBLIC_DEMO_MODE=true
